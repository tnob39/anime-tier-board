AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Native(モバイル)アプリ向けBearer tokenの署名用。AUTH_SECRETとは別の値を設定する（Web/Nativeの署名鍵を分離するため）。
NATIVE_AUTH_SECRET=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
AUTH_URL=https://anime-tier-board.vercel.app
AUTH_TRUST_HOST=true
TMDB_API_KEY=
TMDB_BEARER_TOKEN=
# Vercel Cron(/api/cron/notify)からの呼び出しを認証するBearer token。未設定だとリクエストを拒否する。
CRON_SECRET=
